# 本地 PaddleOCR 辨識後端 URL（預設 localhost:8000）
VITE_BACKEND_URL=http://localhost:8000

# Google OAuth 2.0 Client ID（用於 Google Classroom 登入）
# 請至 https://console.cloud.google.com/apis/credentials 申請
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# 目標老師的 Google Classroom 課程 ID
# 老師在 classroom.google.com 開啟課程後，URL 中的數字即為課程 ID
VITE_CLASSROOM_COURSE_ID=your_course_id_here

# 指定作業 ID（老師建立作業後取得）
VITE_CLASSROOM_COURSEWORK_ID=your_coursework_id_here
